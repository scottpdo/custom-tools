# AWS Credentials
# Option 1: Explicit keys (not recommended for production)
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key

# Option 2: Use a named profile from ~/.aws/credentials
# AWS_PROFILE=default

# AWS Region
AWS_REGION=us-east-1

# S3
S3_BUCKET=your-bucket-name
